{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArxivSummariserAuditEventV17",
  "type": "object",
  "required": ["event_id", "event_time", "tenant_id", "actor", "action", "resource", "result", "correlation_id"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_time": {"type": "string", "format": "date-time"},
    "tenant_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "actor": {
      "type": "object",
      "required": ["subject", "type"],
      "properties": {
        "subject": {"type": "string"},
        "type": {"enum": ["user", "service", "system"]},
        "groups": {"type": "array", "items": {"type": "string"}}
      }
    },
    "action": {"type": "string"},
    "resource": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {"type": "string"},
        "id": {"type": "string"},
        "classification": {"enum": ["public", "internal", "confidential", "restricted"]}
      }
    },
    "result": {"enum": ["success", "failure", "denied"]},
    "source_ip": {"type": "string"},
    "request_id": {"type": "string"},
    "correlation_id": {"type": "string"},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": false
}
