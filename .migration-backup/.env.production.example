# Database (use managed service in prod)
DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/arxiv_copilot

# Redis (use managed Redis in prod)
REDIS_URL=redis://redis-host:6379/0

# Vector store
VECTOR_BACKEND=qdrant
QDRANT_URL=https://your-qdrant-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=arxiv_papers

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Auth
JWT_SECRET=long-random-secret-change-this

# Frontend URL (for CORS)
FRONTEND_URL=https://yourapp.com

# Embedding model (use smaller for faster cold start)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
